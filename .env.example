# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
MONGODB_DATABASE=tactical_hub

# Session security
SESSION_SECRET=<generate-a-long-random-secret>

# Google OAuth web client
# Local callback: http://localhost:3000/api/auth/google/callback
# Production callback: https://<your-domain>/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=<google-web-client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<google-web-client-secret>

# ImageKit product image uploads
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<imagekit-id>
IMAGEKIT_PUBLIC_KEY=<imagekit-public-key>
IMAGEKIT_PRIVATE_KEY=<imagekit-private-key>
# ImageKit upload API rejects spaces in folder names, so use hyphenated path.
IMAGEKIT_PRODUCT_FOLDER=/Tactical-Tune/Products

# Optional admin seed account for scripts/init-mongodb.mjs
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=<temporary-admin-password>

# Optional legacy fallback used by the MongoDB helper when MONGODB_URI is absent
db_user=<mongodb-username>
db_password=<mongodb-password>
